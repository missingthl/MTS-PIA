# ==============================================================================
# PIA Project .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.conda/

# ------------------------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Jupyter Notebook
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ------------------------------------------------------------------------------
# Data files (large, not tracked)
# ------------------------------------------------------------------------------
# Keep code/docs tracked, but exclude local datasets and most vendored archives.
data/
archive/*
!archive/README.md
!archive/reference_code/
archive/reference_code/*
!archive/reference_code/Tensor-CSPNet-and-Graph-CSPNet/
archive/reference_code/Tensor-CSPNet-and-Graph-CSPNet/*
!archive/reference_code/Tensor-CSPNet-and-Graph-CSPNet/utils/
archive/reference_code/Tensor-CSPNet-and-Graph-CSPNet/utils/*
!archive/reference_code/Tensor-CSPNet-and-Graph-CSPNet/utils/functional.py
!archive/reference_code/Tensor-CSPNet-and-Graph-CSPNet/utils/modules.py

# Keep text summaries under out/_active for analysis, but exclude the bulk of
# experiment artifacts and binary outputs.
out/**
!out/README.md
!out/_active/
!out/_active/**/
!out/_active/**/*.md
!out/_active/**/*.csv
!out/_active/**/*.tsv

# Specific large data files
*.cnt
*.fif
*.mat
*.npy
*.npz
*.pkl
*.pickle
*.h5
*.hdf5

# ------------------------------------------------------------------------------
# Logs and Experiment Outputs
# ------------------------------------------------------------------------------
# Keep logs tracked but exclude large binary outputs
logs/**/*.npz
logs/**/*.npy
logs/**/*.pkl
logs/**/*.h5

# Temporary files
tmp/
*.tmp
*.temp

# ------------------------------------------------------------------------------
# Model Checkpoints
# ------------------------------------------------------------------------------
*.pt
*.pth
*.ckpt
checkpoints/

# ------------------------------------------------------------------------------
# OS Generated
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# Coverage / Testing
# ------------------------------------------------------------------------------
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ------------------------------------------------------------------------------
# Documentation builds
# ------------------------------------------------------------------------------
docs/_build/
site/

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
*.log
*.bak
*.orig
.env
.env.*
!.env.example
